profiles {
local {
process.executor= 'local'
docker.enabled= false
}

docker {
process.executor= 'local'
docker.enabled= true

process {
withName: INDEX {
container= 'combinelab/salmon:1.10.1'
}
withName: FASTQC {
container= 'biocontainers/fastqc:v0.11.9_cv8'
}
withName:QUANT {
container= 'combinelab/salmon:1.10.1'
}

withName:MULTIQC {
container='multiqc/multiqc:v1.14'
}
}
}
}

params {
outdir= 'results'
}
